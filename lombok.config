lombok.log.custom.declaration=dev.breezes.settlements.shared.logging.ILogger dev.breezes.settlements.shared.logging.LoggerFactory.getLogger(NAME)

# Copy Dagger @Qualifier annotations from an injected field onto the Lombok-generated constructor
# parameter, so qualified DI (e.g. the executor pools in ConcurrencyModule) resolves to the right
# binding. Without this the qualifier is silently dropped and the wrong binding is injected.
lombok.copyableAnnotations += dev.breezes.settlements.di.PlanGenerationExecutor
lombok.copyableAnnotations += dev.breezes.settlements.di.WorldScanExecutor
