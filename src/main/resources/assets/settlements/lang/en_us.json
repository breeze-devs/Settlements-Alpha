  "dialogue.settlements.generic.idle.1": "Nice breeze today",
  "dialogue.settlements.generic.idle.2": "Always something to do, but not right now",
  "dialogue.settlements.generic.idle.3": "*hums a little tune*",
  "dialogue.settlements.generic.idle.4": "Hope the iron golem is keeping watch",
  "dialogue.settlements.generic.idle.5": "Lovely day for a walk",
  "dialogue.settlements.generic.idle.6": "Another fine day in the village",
  "dialogue.settlements.generic.idle.7": "Stay safe out there",
  "dialogue.settlements.generic.idle.8": "Taking a moment to just breathe",
  "dialogue.settlements.generic.idle.9": "Wonder what the wanderer has for trade today",
  "dialogue.settlements.generic.idle.10": "Beautiful weather we're having",

  "dialogue.settlements.generic.work.1": "Lots to get done before sundown",
  "dialogue.settlements.generic.work.2": "Where did I put that emerald?",
  "dialogue.settlements.generic.work.3": "Busy, busy...",
  "dialogue.settlements.generic.work.4": "Another day, another emerald",
  "dialogue.settlements.generic.work.5": "Can't stop now, I'm on a roll",
  "dialogue.settlements.generic.work.6": "There's always more work to be done",
  "dialogue.settlements.generic.work.7": "Best get back to it",
  "dialogue.settlements.generic.work.8": "Nearly finished with this batch",
  "dialogue.settlements.generic.work.9": "Needs more polish...",
  "dialogue.settlements.generic.work.10": "Time is emeralds",

  "dialogue.settlements.farmer.work.1": "These crops won't harvest themselves",
  "dialogue.settlements.farmer.work.2": "Watch your step, that's freshly tilled!",
  "dialogue.settlements.farmer.work.3": "Soil is looking perfect today",
  "dialogue.settlements.farmer.work.4": "Need to get these carrots pulled",
  "dialogue.settlements.farmer.work.5": "Hoping for a bit of rain tonight",
  "dialogue.settlements.farmer.work.6": "Chickens better stay away from these seeds",
  "dialogue.settlements.farmer.work.7": "Just a few more rows to hoe",
  "dialogue.settlements.farmer.work.8": "This bone meal works wonders",
  "dialogue.settlements.farmer.work.9": "Gotta beat the sunset",
  "dialogue.settlements.farmer.work.10": "Weeds, weeds everywhere...",

  "dialogue.settlements.farmer.idle.1": "Nothing like the smell of fresh dirt",
  "dialogue.settlements.farmer.idle.2": "Taking a quick breather, my back aches",
  "dialogue.settlements.farmer.idle.3": "Think I'll just watch the wheat grow for a minute",
  "dialogue.settlements.farmer.idle.4": "Good harvest this season",
  "dialogue.settlements.farmer.idle.5": "Wonder if the composter is full yet",
  "dialogue.settlements.farmer.idle.6": "Have you seen the harvest this season?",
  "dialogue.settlements.farmer.idle.7": "Rain would be nice right about now",
  "dialogue.settlements.farmer.idle.8": "Best crops in the whole biome",
  "dialogue.settlements.farmer.idle.9": "Phew, time to stretch",
  "dialogue.settlements.farmer.idle.10": "A farmer's work is never done, but I'm pausing anyway",

  "dialogue.settlements.nitwit.idle.1": "Huh?",
  "dialogue.settlements.nitwit.idle.2": "Is it bedtime yet?",
  "dialogue.settlements.nitwit.idle.3": "Uh... what was I doing?",
  "dialogue.settlements.nitwit.idle.4": "I lost my green shirt... oh wait, I'm wearing it",
  "dialogue.settlements.nitwit.idle.5": "*yawns loudly*",
  "dialogue.settlements.nitwit.idle.6": "I like looking at the clouds",
  "dialogue.settlements.nitwit.idle.7": "Do you have any bread?",
  "dialogue.settlements.nitwit.idle.8": "I'm too tired to think",
  "dialogue.settlements.nitwit.idle.9": "Grass is soft...",
  "dialogue.settlements.nitwit.idle.10": "Maybe I should ring the bell",

  "dialogue.settlements.generic.panic.1": "Run!",
  "dialogue.settlements.generic.panic.2": "Help me!",
  "dialogue.settlements.generic.panic.3": "Get away!",
  "dialogue.settlements.generic.panic.4": "Ahhh!",
  "dialogue.settlements.generic.panic.5": "Save us!",
  "dialogue.settlements.generic.panic.6": "We're under attack!",
  "dialogue.settlements.generic.panic.7": "Flee!",
  "dialogue.settlements.generic.panic.8": "Don't let them get us!",
  "dialogue.settlements.generic.panic.9": "Look out!",
  "dialogue.settlements.generic.panic.10": "Where's the golem?!",

  "dialogue.settlements.generic.meet.1": "Good to see everyone",
  "dialogue.settlements.generic.meet.2": "Any news from the neighboring village?",
  "dialogue.settlements.generic.meet.3": "Bell rings, we gather",
  "dialogue.settlements.generic.meet.4": "Nice catching up with you",
  "dialogue.settlements.generic.meet.5": "So, how were trades today?",
  "dialogue.settlements.generic.meet.6": "Always nice to see a friendly face",
  "dialogue.settlements.generic.meet.7": "Did you hear the latest gossip?",
  "dialogue.settlements.generic.meet.8": "Taking a break by the well?",
  "dialogue.settlements.generic.meet.9": "Gather round, gather round",
  "dialogue.settlements.generic.meet.10": "It's been a busy day",

  "dialogue.settlements.generic.morning.1": "Good morning!",
  "dialogue.settlements.generic.morning.2": "Sun's up, time to work",
  "dialogue.settlements.generic.morning.3": "A fresh start",
  "dialogue.settlements.generic.morning.4": "Did you sleep well?",
  "dialogue.settlements.generic.morning.5": "I ate too much for breakfast",
  "dialogue.settlements.generic.morning.6": "Morning already?",
  "dialogue.settlements.generic.morning.7": "Ready for a new day",
  "dialogue.settlements.generic.morning.8": "Hope the zombies are all gone",
  "dialogue.settlements.generic.morning.9": "*yawns* Good morning",
  "dialogue.settlements.generic.morning.10": "The village looks peaceful at dawn",

  "dialogue.settlements.generic.evening.1": "Sun's getting low",
  "dialogue.settlements.generic.evening.2": "Time to pack up",
  "dialogue.settlements.generic.evening.3": "Almost bedtime",
  "dialogue.settlements.generic.evening.4": "Keep an eye out, it's getting dark",
  "dialogue.settlements.generic.evening.5": "Good evening",
  "dialogue.settlements.generic.evening.6": "The day is almost over",
  "dialogue.settlements.generic.evening.7": "Ready to rest my feet",
  "dialogue.settlements.generic.evening.8": "Lock your doors tonight",
  "dialogue.settlements.generic.evening.9": "Let's head inside",
  "dialogue.settlements.generic.evening.10": "The stars are coming out",

  "dialogue.settlements.generic.rest_day.1": "So glad for a day off",
  "dialogue.settlements.generic.rest_day.2": "Great weather for a break",
  "dialogue.settlements.generic.rest_day.3": "Finally, some time to relax",
  "dialogue.settlements.generic.rest_day.4": "Not lifting a finger today",
  "dialogue.settlements.generic.rest_day.5": "Just going to stroll around the village",
  "dialogue.settlements.generic.rest_day.6": "Perfect day to do absolutely nothing",
  "dialogue.settlements.generic.rest_day.7": "Have you been enjoying the rest?",
  "dialogue.settlements.generic.rest_day.8": "No emeralds to count today",
  "dialogue.settlements.generic.rest_day.9": "Ah, peace and quiet",
  "dialogue.settlements.generic.rest_day.10": "*yawns* Think I'll take a nap later",

  "dialogue.settlements.generic.zombie_sighted.1": "Zombie!",
  "dialogue.settlements.generic.zombie_sighted.2": "Look out, the undead!",
  "dialogue.settlements.generic.zombie_sighted.3": "Golem, over here!",

  "dialogue.settlements.farmer.rest_day.1": "Letting the fields water themselves today",
  "dialogue.settlements.farmer.rest_day.2": "The crops can wait for tomorrow",
  "dialogue.settlements.farmer.rest_day.3": "Nice to just sit and watch the wheat sway",
  "dialogue.settlements.farmer.rest_day.4": "Even a farmer needs a day out of the sun",
  "dialogue.settlements.farmer.rest_day.5": "No hoeing or sowing today",

  "dialogue.settlements.farmer.zombie_sighted.1": "Get out of my crops, you monster!",
  "dialogue.settlements.farmer.zombie_sighted.2": "Zombie trampling the farmland!",
  "dialogue.settlements.farmer.zombie_sighted.3": "Protect the harvest from that thing!",
  "dialogue.settlements.farmer.zombie_sighted.4": "Shoo! Get out of the wheat!",
  "dialogue.settlements.farmer.zombie_sighted.5": "It's stepping on the carrots!",
  "dialogue.settlements.farmer.zombie_sighted.6": "Defend the fields!",
  "dialogue.settlements.farmer.zombie_sighted.7": "Stay away from my potatoes!",
  "dialogue.settlements.farmer.zombie_sighted.8": "My beautiful tilled soil, ruined!",

  "dialogue.settlements.generic.idle.cured.1": "I can't stand the smell of rotten flesh anymore",
  "dialogue.settlements.generic.idle.cured.2": "The potion... it burned, but it saved me",
  "dialogue.settlements.generic.idle.cured.3": "I have nightmares about the darkness",
  "dialogue.settlements.generic.idle.cured.4": "I still feel a bit sluggish sometimes",
  "dialogue.settlements.generic.idle.cured.5": "I owe my life to that golden apple",

  "dialogue.settlements.generic.rest_day.cured.1": "Just happy to be standing in the sun",
  "dialogue.settlements.generic.rest_day.cured.2": "I used to wander endlessly, now I can just rest",
  "dialogue.settlements.generic.rest_day.cured.3": "A restful day is a beautiful thing",

  "subtitles.settlements.cucco_call": "A chicken crows ominously",
  "subtitles.settlements.cucco_fall": "A chicken falls ominously",
  "subtitles.settlements.wololo": "A shepherd chants mysteriously",

  "action.settlements.chest.waxed": "Chest waxed, villagers will ignore it",
  "action.settlements.chest.unwaxed": "Chest unwaxed, villagers may use it again"

